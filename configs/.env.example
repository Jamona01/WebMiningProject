# Reddit API
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=web-mining-project/0.1

# X (Twitter) API
X_BEARER_TOKEN=
X_API_KEY=
X_API_SECRET=

# twscrape account pool (JSON array — one account is enough to start)
#
# Option A — Cookie-based (recommended, no email password needed):
#   1. Log in to x.com in your browser
#   2. Open DevTools (F12) → Application → Cookies → x.com
#   3. Copy the values of "ct0" and "auth_token"
#   4. Paste them into the JSON below:
#   [{"username": "your_x_handle", "cookies": "ct0=YOUR_CT0_VALUE;auth_token=YOUR_AUTH_TOKEN_VALUE"}]
#
# Option B — Password-based (needs real email_password for verification):
#   [{"username": "u", "password": "p", "email": "e", "email_password": "ep"}]
#
TWSCRAPE_ACCOUNTS=[{"username": "your_x_handle", "cookies": "ct0=PASTE_HERE;auth_token=PASTE_HERE"}]

# News API (e.g. newsapi.org)
NEWS_API_KEY=

# Raspberry Pi / ARM: path to system Chromium (Playwright has no ARM build)
# Install with: sudo apt install -y chromium-browser
# Then set:
# CHROMIUM_EXECUTABLE=/usr/bin/chromium-browser
CHROMIUM_EXECUTABLE=
